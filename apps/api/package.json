    "drizzle-orm": "^0.43.1",
    "hono": "^4.7.10",
    "hono-openapi": "^0.4.8",
    "pg": "^8.16.0",
    "zod": "^3.25.23",
    "zod-openapi": "^4.2.4"
  },
  "devDependencies": {
    "@types/pg": "^8.15.2",
    "bun-types": "^1.2.14",
    "drizzle-kit": "^0.31.1"
  }
}
